{
  "extends": "./tsconfig.app.json",

  // Override to include only test files and clear exclusions.
  // Application code imported in tests is automatically included via module resolution.
  "include": ["src/**/__tests__/*", "src/**/*.test.ts", "src/**/*.spec.ts", "env.d.ts"],
  "exclude": [],

  "compilerOptions": {
    // Vitest runs in a different environment than the application code.
    // Adjust lib and types accordingly. ES2022 matches the app's target so
    // newer built-ins (e.g. Array.prototype.at) are available in tests.
    "lib": ["ES2022"],
    "types": ["node", "jsdom"],

    // noUncheckedIndexedAccess produces false positives in tests where the
    // test author controls the data and index bounds are known.
    "noUncheckedIndexedAccess": false,

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo"
  }
}
